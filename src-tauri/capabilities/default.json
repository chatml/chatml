{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "code",
          "cmd": "code",
          "args": [
            {
              "validator": "regex",
              "value": "^[/~.][-\\w\\s./~]+$"
            }
          ]
        },
        {
          "name": "open-terminal",
          "cmd": "open",
          "args": [
            "-a",
            "Terminal",
            {
              "validator": "regex",
              "value": "^[/~][-\\w\\s./~]+$"
            }
          ]
        },
        {
          "name": "open-finder",
          "cmd": "open",
          "args": [
            "-R",
            {
              "validator": "regex",
              "value": "^[/~][-\\w\\s./~]+$"
            }
          ]
        }
      ]
    },
    "updater:default",
    "process:allow-restart",
    "window-state:default",
    "dialog:default",
    "core:tray:default",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "pty:default",
    "pty:allow-spawn",
    "pty:allow-write",
    "pty:allow-resize",
    "pty:allow-kill",
    "mcp-bridge:default",
    "deep-link:default",
    "stronghold:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ]
}
